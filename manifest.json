{
    "name": "Music Analyzer Pro",
    "short_name": "MAP",
    "description": "Professional Music Analysis & Management System",
    "version": "2.0.0",
    "manifest_version": 3,
    "start_url": "/index-with-search.html",
    "display": "standalone",
    "orientation": "any",
    "theme_color": "#764ba2",
    "background_color": "#667eea",
    "scope": "/",
    "lang": "es",
    "dir": "ltr",
    "categories": ["music", "productivity", "utilities"],
    "icons": [
