{
    "name": "map-music-analyzer",
    "version": "1.0.0",
    "description": "MAP - Music Analyzer Pro by BlueSystemIO",
    "displayName": "MAP - Music Analyzer Pro",
    "codename": "MAP",
    "main": "main-minimal.js",
    "scripts": {
        "start": "electron .",
        "dev": "webpack serve --mode development --open",
        "build": "webpack --mode production",
        "build:analyze": "ANALYZE=true webpack --mode production",
        "electron": "electron .",
        "electron:dev": "NODE_ENV=development electron .",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:unit": "node tests/test-suite.js",
        "test:performance": "node tests/performance-test.js",
        "test:stress": "node tests/stress-test.js",
        "test:benchmark": "node tests/benchmark-suite.js",
        "test:all": "npm run test && npm run test:performance && npm run test:stress",
        "extract-artwork": "node extract-artwork.js",
        "create-indexes": "node create-indexes.js",
        "validate:artwork": "node validate-and-fix-artwork.js",
        "validate:quick": "node validate-and-fix-artwork.js --quick",
        "fix:paths": "node fix-all-paths.js",
        "fix:all": "npm run fix:paths && npm run validate:artwork",
        "import": "node import/import-all.js",
        "import:test": "node import/import-all.js --limit=100",
        "import:resume": "node import/import-all.js --resume",
        "import:scan": "node import/scan-music.js",
        "clean": "rm -rf dist node_modules package-lock.json",
        "reinstall": "npm run clean && npm install",
        "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
        "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json,css,md}\"",
        "typecheck": "tsc --noEmit",
        "prebuild": "npm run lint && npm run typecheck",
        "postinstall": "electron-builder install-app-deps",
        "pack": "electron-builder --dir",
        "dist": "electron-builder --mac --win --linux",
        "dist:mac": "electron-builder --mac",
        "dist:win": "electron-builder --win",
        "dist:linux": "electron-builder --linux"
    },
    "build": {
        "appId": "com.bluesystemio.map",
        "productName": "MAP",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "assets/**/*",
            "artwork-cache/**/*",
            "!**/*.ts",
            "!*.code-workspace",
            "!.gitignore",
            "!README.md",
            "!dist",
            "!test-*.js",
            "!check-*.js",
            "!fix-*.js",
            "!continue-*.js"
        ],
        "extraResources": [
            {
                "from": "assets",
                "to": "assets",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "mac": {
            "category": "public.app-category.music",
            "icon": "assets/icons/icon.icns",
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "win": {
            "target": "nsis",
            "icon": "assets/icons/icon.ico"
        },
        "linux": {
            "target": "AppImage",
            "icon": "assets/icons/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "keywords": [
        "music",
        "analyzer",
        "electron"
    ],
    "author": {
        "name": "BlueSystemIO",
        "email": "audio@bluesystemio.com"
    },
    "license": "MIT",
    "devDependencies": {
        "@babel/core": "^7.28.3",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
        "@babel/plugin-proposal-optional-chaining": "^7.21.0",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-transform-runtime": "^7.24.0",
        "@babel/preset-env": "^7.28.3",
        "@babel/preset-typescript": "^7.23.3",
        "@types/howler": "^2.2.11",
        "@types/node": "^20.11.24",
        "@typescript-eslint/eslint-plugin": "^7.1.0",
        "@typescript-eslint/parser": "^7.1.0",
        "autoprefixer": "^10.4.18",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.1.3",
        "compression-webpack-plugin": "^11.1.0",
        "copy-webpack-plugin": "^12.0.2",
        "css-loader": "^6.10.0",
        "css-minimizer-webpack-plugin": "^6.0.0",
        "cssnano": "^6.1.0",
        "electron": "^32.2.10",
        "electron-builder": "^26.0.12",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "glob": "^11.0.3",
        "html-webpack-plugin": "^5.6.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "mini-css-extract-plugin": "^2.8.1",
        "path-browserify": "^1.0.1",
        "postcss": "^8.4.35",
        "postcss-loader": "^8.1.1",
        "postcss-preset-env": "^9.4.0",
        "prettier": "^3.2.5",
        "style-loader": "^3.3.4",
        "terser-webpack-plugin": "^5.3.10",
        "typescript": "^5.3.3",
        "webpack": "^5.90.3",
        "webpack-bundle-analyzer": "^4.10.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.2",
        "workbox-webpack-plugin": "^7.0.0"
    },
    "dependencies": {
        "@babel/runtime": "^7.24.0",
        "chart.js": "^4.4.2",
        "date-fns": "^3.3.1",
        "dexie": "^3.2.5",
        "dotenv": "^17.2.1",
        "express": "^5.1.0",
        "howler": "^2.2.4",
        "idb": "^8.0.0",
        "localforage": "^1.10.0",
        "music-metadata": "^7.14.0",
        "node-fetch": "^2.7.0",
        "node-id3": "^0.2.9",
        "sharp": "^0.34.3",
        "sortablejs": "^1.15.2",
        "sqlite3": "^5.1.7",
        "web-vitals": "^3.5.2",
        "workbox-cacheable-response": "^7.0.0",
        "workbox-core": "^7.0.0",
        "workbox-expiration": "^7.0.0",
        "workbox-precaching": "^7.0.0",
        "workbox-routing": "^7.0.0",
        "workbox-strategies": "^7.0.0",
        "xmlbuilder": "^15.1.1"
    }
}
